    "\n",
    "    y_pred = pd.Series(classifier.predict(X_proc), index=X_proc.index)\n",
    "\n",
    "    print(classification_report(y_true, y_pred))\n",
    "\n",
    "    report_df = pd.DataFrame(\n",
